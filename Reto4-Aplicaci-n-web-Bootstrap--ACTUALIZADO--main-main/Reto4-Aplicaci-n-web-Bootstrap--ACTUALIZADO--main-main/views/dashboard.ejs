<% const total=juegos.length; const completed=juegos.filter(j=> j.estado === 'Completado').length;
    const pending = juegos.filter(j => j.estado === 'Pendiente').length;
    %>

    <div class="row g-3 mb-5 fade-in-up">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100 p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Total Juegos</h6>
                        <h2 class="mb-0 fw-bold text-dark">
                            <%= total %>
                        </h2>
                    </div>
                    <div class="bg-light p-3 rounded-circle text-primary">
                        <i class="bi bi-collection-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100 p-3" style="border-left-color: var(--success);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Completados</h6>
                        <h2 class="mb-0 fw-bold text-success">
                            <%= completed %>
                        </h2>
                    </div>
                    <div class="bg-light p-3 rounded-circle text-success">
                        <i class="bi bi-trophy-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100 p-3" style="border-left-color: var(--warning);">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase small fw-bold mb-1">Pendientes</h6>
                        <h2 class="mb-0 fw-bold text-warning">
                            <%= pending %>
                        </h2>
                    </div>
                    <div class="bg-light p-3 rounded-circle text-warning">
                        <i class="bi bi-hourglass-split fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4 fade-in-up" style="animation-delay: 0.1s;">
        <div class="d-flex align-items-center gap-3">
            <h4 class="fw-bold m-0">Biblioteca</h4>
            <div class="btn-group shadow-sm bg-white rounded-pill p-1 border" role="group">
                <input type="radio" class="btn-check" name="viewMode" id="viewFav" autocomplete="off" checked>
                <label class="btn btn-outline-primary border-0 rounded-pill px-3 py-1" for="viewFav">
                    <i class="bi bi-star-fill me-1"></i> Favoritos
                </label>

                <input type="radio" class="btn-check" name="viewMode" id="viewAll" autocomplete="off">
                <label class="btn btn-outline-primary border-0 rounded-pill px-3 py-1" for="viewAll">
                    Todos
                </label>
            </div>
        </div>
        <button class="btn btn-primary-gradient rounded-pill px-4 shadow-sm" data-bs-toggle="modal"
            data-bs-target="#modalJuego" data-action="create">
            <i class="bi bi-plus-lg me-2"></i>Nuevo Juego
        </button>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-5 fade-in-up" style="animation-delay: 0.2s;">
        <div class="card-body p-4">
            <form action="/dashboard" method="GET" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted fw-bold">PLATAFORMA</label>
                    <select name="plataforma" class="form-select bg-light border-0">
                        <option value="">Todas</option>
                        <option value="PC" <%=filters.plataforma==='PC' ? 'selected' : '' %>>PC</option>
                        <option value="PlayStation" <%=filters.plataforma==='PlayStation' ? 'selected' : '' %>
                            >PlayStation</option>
                        <option value="Xbox" <%=filters.plataforma==='Xbox' ? 'selected' : '' %>>Xbox</option>
                        <option value="Nintendo" <%=filters.plataforma==='Nintendo' ? 'selected' : '' %>>Nintendo
                        </option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted fw-bold">ESTADO</label>
                    <select name="estado" class="form-select bg-light border-0">
                        <option value="">Todos</option>
                        <option value="Pendiente" <%=filters.estado==='Pendiente' ? 'selected' : '' %>>Pendiente
                        </option>
                        <option value="Jugando" <%=filters.estado==='Jugando' ? 'selected' : '' %>>Jugando</option>
                        <option value="Completado" <%=filters.estado==='Completado' ? 'selected' : '' %>>Completado
                        </option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted fw-bold">BÚSQUEDA</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="genero" class="form-control bg-light border-0"
                            placeholder="Buscar por género..." value="<%= filters.genero || '' %>">
                    </div>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-dark w-100 rounded-pill">Filtrar</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('partials/game-list') %>