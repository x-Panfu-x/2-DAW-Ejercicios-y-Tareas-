<div class="modal fade" id="modalJuego" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-light border-0 p-4 pb-0">
                <h5 class="modal-title fw-bold text-primary" id="modalTitle">
                    <i class="bi bi-joystick me-2"></i>Nuevo Juego
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-3">
                <form id="formJuego" method="POST" action="/videojuegos/crear">
                    <input type="hidden" name="id" id="gameId">
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase">Título del Juego</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-primary"><i class="bi bi-fonts"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" name="titulo" id="titulo" required placeholder="Ej: The Legend of Zelda">
                        </div>
                    </div>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Plataforma</label>
                            <select class="form-select" name="plataforma" id="plataforma" required>
                                <option value="PC">PC</option>
                                <option value="PlayStation">PlayStation</option>
                                <option value="Xbox">Xbox</option>
                                <option value="Nintendo">Nintendo</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-muted text-uppercase">Estado</label>
                            <select class="form-select" name="estado" id="estado" required>
                                <option value="Pendiente">Pendiente</option>
                                <option value="Jugando">Jugando</option>
                                <option value="Completado">Completado</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Género</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-primary"><i class="bi bi-tag"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" name="genero" id="genero" placeholder="Ej: Aventura, RPG...">
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary-gradient py-2 rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-save me-2"></i>Guardar Juego
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>